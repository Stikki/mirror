aws_region    = "eu-north-1"
instance_type = "t3.nano"
domain        = "mirror.stikki.ninja"

# Path to your SSH public key for EC2 admin access
ssh_pubkey_path = "~/.ssh/id_ed25519.pub"

# The mirror tunnel user's authorized key (paste full line from .pub file)
mirror_authorized_key = "ssh-rsa AAAA... master-of-universe"

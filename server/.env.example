#
# Required
#
MIRROR_HOST=mirror.example.com

#
# Optional (with defaults)
#
# Internal tunnel port inside the container — sshd binds it, angie proxies to it.
MIRROR_PORT=7000

# TLS mode: "auto" mounts /etc/letsencrypt certs, "off" for HTTP-only.
MIRROR_TLS=auto

# Host port mappings
MIRROR_HTTP_PORT=80
MIRROR_HTTPS_PORT=443
MIRROR_SSH_PORT=2022
